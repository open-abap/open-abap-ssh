{
  "name": "open-abap-ssh",
  "version": "1.0.0",
  "private": true,
  "description": "open-abap-ssh",
  "scripts": {
    "test": "npm run test:dependencies && npx abaplint && npm run unit",
    "test:dependencies": "node --test scripts/check-platform-dependencies.test.mjs scripts/check-apc-adapter.test.mjs && node scripts/check-platform-dependencies.mjs",
    "build": "rimraf output && abap_transpile test/abap_transpile.json && node scripts/enable-sha512-runtime.mjs",
    "unit": "npm run build && echo RUNNING && node output/index.mjs",
    "integration:transport": "npm run build && node integration/transport.mjs",
    "integration:auth": "npm run build && node integration/auth.mjs",
    "integration:exec": "npm run build && node integration/exec.mjs",
    "integration:sftp": "npm run build && node integration/sftp.mjs",
    "integration:rebex": "npm run build && node integration/rebex.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-abap/open-abap-ssh.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/open-abap/open-abap-ssh/issues"
  },
  "homepage": "https://github.com/open-abap/open-abap-ssh#readme",
  "dependencies": {
    "@abaplint/cli": "^2.119.65",
    "@abaplint/runtime": "^2.13.40",
    "@abaplint/transpiler-cli": "^2.13.40"
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  }
}
