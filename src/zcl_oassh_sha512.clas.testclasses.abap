CLASS ltcl_test DEFINITION FOR TESTING DURATION SHORT RISK LEVEL HARMLESS FINAL.
  PRIVATE SECTION.
    METHODS nist_vectors FOR TESTING.
ENDCLASS.


CLASS ltcl_test IMPLEMENTATION.
  METHOD nist_vectors.
    DATA lv_empty TYPE xstring.
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_sha512=>hash( lv_empty )
      exp = 'CF83E1357EEFB8BDF1542850D66D8007D620E4050B5715DC83F4A921D36CE9CE'
        && '47D0D13C5D85F2B0FF8318D2877EEC2F63B931BD47417A81A538327AF927DA3E' ).
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_sha512=>hash( '616263' )
      exp = 'DDAF35A193617ABACC417349AE20413112E6FA4E89A97EA20A9EEEE64B55D39A'
        && '2192992A274FC1A836BA3C23A3FEEBBD454D4423643CE80E2A9AC94FA54CA49F' ).
  ENDMETHOD.
ENDCLASS.

