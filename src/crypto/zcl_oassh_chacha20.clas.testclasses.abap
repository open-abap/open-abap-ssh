CLASS ltcl_test DEFINITION FOR TESTING DURATION SHORT RISK LEVEL HARMLESS FINAL.
  PRIVATE SECTION.
    METHODS rfc8439_block FOR TESTING.
    METHODS openssh_stream FOR TESTING.
ENDCLASS.


CLASS ltcl_test IMPLEMENTATION.
  METHOD rfc8439_block.
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_chacha20=>block_ietf(
        iv_key     = '000102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F'
        iv_counter = 1
        iv_nonce   = '000000090000004A00000000' )
      exp = '10F1E7E4D13B5915500FDD1FA32071C4C7D1F4C733C068030422AA9AC3D46C4E'
        && 'D2826446079FAA0914C2D705D98B02A2B5129CD1DE164EB9CBD083E8A2503C4E' ).
  ENDMETHOD.


  METHOD openssh_stream.
* Independent Node.js/OpenSSL chacha20 vector using a 64-bit LE counter
* followed by the eight nonce bytes, matching OpenSSH's cipher core.
    CONSTANTS:
      lc_plain_1 TYPE xstring VALUE '000102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F',
      lc_plain_2 TYPE xstring VALUE '202122232425262728292A2B2C2D2E2F303132333435363738393A3B3C3D3E3F',
      lc_plain_3 TYPE xstring VALUE '404142434445464748494A4B4C4D4E4F505152535455565758595A5B5C5D5E5F'.
    DATA lv_plain TYPE xstring.
    CONCATENATE lc_plain_1 lc_plain_2 lc_plain_3 INTO lv_plain IN BYTE MODE.
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_chacha20=>crypt_ssh(
        iv_key     = '000102030405060708090A0B0C0D0E0F101112131415161718191A1B1C1D1E1F'
        iv_nonce   = '0000000000000007'
        iv_counter = 1
        iv_data    = lv_plain )
      exp = '284717404A862C596464B1FBDB82DD2324A322256AF62B94587301C49C4E1D4B'
        && '8476D3863147D29E84FB4C053F1F2558479DA2ECAB167EC442DD1C81EF9369CE'
        && '4583A779650712A16CA1C5A82A08B3BF389C41EFA960A2A59ECD67A03A662F69' ).
  ENDMETHOD.
ENDCLASS.
