  METHOD prime_and_bounds.
    DATA lv_prime TYPE xstring.
    DATA lv_p_minus_one TYPE xstring.
    DATA lv_zero TYPE xstring.
    lv_prime = zcl_oassh_group14=>prime( ).
    cl_abap_unit_assert=>assert_equals(
      act = xstrlen( lv_prime )
      exp = 256 ).
    cl_abap_unit_assert=>assert_true( zcl_oassh_group14=>is_valid_public( '02' ) ).
    cl_abap_unit_assert=>assert_false( zcl_oassh_group14=>is_valid_public( lv_zero ) ).
    cl_abap_unit_assert=>assert_false( zcl_oassh_group14=>is_valid_public( '01' ) ).
    cl_abap_unit_assert=>assert_false( zcl_oassh_group14=>is_valid_public( lv_prime ) ).
    lv_p_minus_one = zcl_oassh_bigint=>subtract(
      iv_a = lv_prime
      iv_b = '01' ).
    cl_abap_unit_assert=>assert_false( zcl_oassh_group14=>is_valid_public( lv_p_minus_one ) ).
  ENDMETHOD.


  METHOD public_vector.
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_group14=>public_key( c_private )
      exp = expected_public( ) ).
  ENDMETHOD.


  METHOD shared_vector.
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_group14=>shared_secret(
        iv_peer_public = peer_public( )
        iv_private     = c_private )
      exp = expected_secret( ) ).
  ENDMETHOD.
ENDCLASS.
