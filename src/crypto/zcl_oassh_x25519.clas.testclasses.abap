CLASS ltcl_test DEFINITION FOR TESTING DURATION LONG RISK LEVEL HARMLESS FINAL.

  PRIVATE SECTION.
    METHODS rfc7748_vector1 FOR TESTING RAISING cx_static_check.
    METHODS rfc7748_vector2 FOR TESTING RAISING cx_static_check.
    METHODS base_point FOR TESTING RAISING cx_static_check.
ENDCLASS.


CLASS ltcl_test IMPLEMENTATION.

  METHOD rfc7748_vector1.
* RFC 7748 section 5.2, first test vector
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_x25519=>scalarmult(
        iv_scalar = 'A546E36BF0527C9D3B16154B82465EDD62144C0AC1FC5A18506A2244BA449AC4'
        iv_u      = 'E6DB6867583030DB3594C1A424B15F7C726624EC26B3353B10A903A6D0AB1C4C' )
      exp = 'C3DA55379DE9C6908E94EA4DF28D084F32ECCF03491C71F754B4075577A28552' ).
  ENDMETHOD.

  METHOD rfc7748_vector2.
* RFC 7748 section 5.2, second test vector
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_x25519=>scalarmult(
        iv_scalar = '4B66E9D4D1B4673C5AD22691957D6AF5C11B6421E0EA01D42CA4169E7918BA0D'
        iv_u      = 'E5210F12786811D3F4B7959D0538AE2C31DBE7106FC03C3EFC4CD549C715A493' )
      exp = '95CBDE9476E8907D7AADE45CB4B873F88B595A68799FA152E6F8F7647AAC7957' ).
  ENDMETHOD.

  METHOD base_point.
* RFC 7748 section 6.1, Alice's public key = scalarmult_base(private)
    cl_abap_unit_assert=>assert_equals(
      act = zcl_oassh_x25519=>scalarmult_base(
        iv_scalar = '77076D0A7318A57D3C16C17251B26645DF4C2F87EBC0992AB177FBA51DB92C2A' )
      exp = '8520F0098930A754748B7DDCB43EF75A0DBF3A0D26381AF4EBA4A98EAA9B4E6A' ).
  ENDMETHOD.

ENDCLASS.
